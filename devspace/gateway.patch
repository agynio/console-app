+) ([]*secretsv1.SecretProvider, bool) {
+	if organizationID == "" {
+		return providers, false
+	}
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	filtered := make([]*secretsv1.SecretProvider, 0, len(providers))
+	conflict := false
+	for _, provider := range providers {
