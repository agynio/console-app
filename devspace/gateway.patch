 func (g *UsersGateway) CreateAPIToken(ctx context.Context, req *connect.Request[usersv1.CreateAPITokenRequest]) (*connect.Response[usersv1.CreateAPITokenResponse], error) {
diff --git a/internal/gateway/users_fallback.go b/internal/gateway/users_fallback.go
new file mode 100644
index 0000000..8adaba6
--- /dev/null
+++ b/internal/gateway/users_fallback.go
@@ -0,0 +1,112 @@
+package gateway
+
+import (
+	"sync"
+
+	usersv1 "github.com/agynio/gateway/gen/agynio/api/users/v1"
+)
+
+type userFallbackStore struct {
+	mu        sync.RWMutex
+	usersByID map[string]*usersv1.User
+}
+
+func newUserFallbackStore() *userFallbackStore {
+	return &userFallbackStore{
+		usersByID: make(map[string]*usersv1.User),
+	}
+}
+
+func (s *userFallbackStore) recordUser(user *usersv1.User) {
+	if user == nil {
+		return
+	}
+	identityID := user.GetMeta().GetId()
+	if identityID == "" {
+		return
+	}
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	s.usersByID[identityID] = user
+}
+
+func (s *userFallbackStore) recordUsers(users []*usersv1.User) {
+	for _, user := range users {
+		s.recordUser(user)
+	}
+}
+
+func (s *userFallbackStore) getUser(identityID string) (*usersv1.User, bool) {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	user, ok := s.usersByID[identityID]
+	return user, ok
+}
+
+func (s *userFallbackStore) listUsers() []*usersv1.User {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	users := make([]*usersv1.User, 0, len(s.usersByID))
+	for _, user := range s.usersByID {
+		users = append(users, user)
+	}
+	return users
+}
+
+func (s *userFallbackStore) listUsersByIDs(identityIDs []string) []*usersv1.User {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	seen := make(map[string]struct{}, len(identityIDs))
+	users := make([]*usersv1.User, 0, len(identityIDs))
+	for _, identityID := range identityIDs {
+		if identityID == "" {
+			continue
+		}
+		if _, ok := seen[identityID]; ok {
+			continue
+		}
+		seen[identityID] = struct{}{}
+		if user, ok := s.usersByID[identityID]; ok {
+			users = append(users, user)
+		}
+	}
+	return users
+}
+
+func mergeUsers(primary []*usersv1.User, fallback []*usersv1.User) []*usersv1.User {
+	if len(fallback) == 0 {
+		return primary
+	}
+	merged := make([]*usersv1.User, 0, len(primary)+len(fallback))
+	seen := make(map[string]struct{}, len(primary))
+	for _, user := range primary {
+		if user == nil {
+			continue
+		}
+		identityID := user.GetMeta().GetId()
+		if identityID == "" {
+			merged = append(merged, user)
+			continue
+		}
+		if _, ok := seen[identityID]; ok {
+			continue
+		}
+		seen[identityID] = struct{}{}
+		merged = append(merged, user)
+	}
+	for _, user := range fallback {
+		if user == nil {
+			continue
+		}
+		identityID := user.GetMeta().GetId()
+		if identityID == "" {
+			continue
+		}
+		if _, ok := seen[identityID]; ok {
+			continue
+		}
+		seen[identityID] = struct{}{}
+		merged = append(merged, user)
+	}
+	return merged
+}
