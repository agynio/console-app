diff --git a/internal/gateway/organizations_fallback.go b/internal/gateway/organizations_fallback.go
new file mode 100644
index 0000000..81a6c55
--- /dev/null
+++ b/internal/gateway/organizations_fallback.go
@@ -0,0 +1,260 @@
+package gateway
+
+import (
+	"sync"
+
+	organizationsv1 "github.com/agynio/gateway/gen/agynio/api/organizations/v1"
+	"github.com/google/uuid"
+	"google.golang.org/protobuf/types/known/timestamppb"
+)
+
+type organizationFallbackStore struct {
+	mu                       sync.RWMutex
+	organizations            map[string]*organizationsv1.Organization
+	membershipsByID          map[string]*organizationsv1.Membership
+	membershipsByOrgIdentity map[string]map[string]string
+}
+
+func newOrganizationFallbackStore() *organizationFallbackStore {
+	return &organizationFallbackStore{
+		organizations:            make(map[string]*organizationsv1.Organization),
+		membershipsByID:          make(map[string]*organizationsv1.Membership),
+		membershipsByOrgIdentity: make(map[string]map[string]string),
+	}
+}
+
+func (s *organizationFallbackStore) recordOrganization(org *organizationsv1.Organization) {
+	if org == nil || org.Id == "" {
+		return
+	}
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	s.organizations[org.Id] = org
+}
+
+func (s *organizationFallbackStore) recordOrganizations(organizations []*organizationsv1.Organization) {
+	for _, org := range organizations {
+		s.recordOrganization(org)
+	}
+}
+
+func (s *organizationFallbackStore) listOrganizations() []*organizationsv1.Organization {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	organizations := make([]*organizationsv1.Organization, 0, len(s.organizations))
+	for _, org := range s.organizations {
+		organizations = append(organizations, org)
+	}
+	return organizations
+}
+
+func (s *organizationFallbackStore) recordMembership(membership *organizationsv1.Membership) {
+	if membership == nil || membership.Id == "" {
+		return
+	}
+
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	s.membershipsByID[membership.Id] = membership
+	if membership.OrganizationId == "" || membership.IdentityId == "" {
+		return
+	}
+	byIdentity, ok := s.membershipsByOrgIdentity[membership.OrganizationId]
+	if !ok {
+		byIdentity = make(map[string]string)
+		s.membershipsByOrgIdentity[membership.OrganizationId] = byIdentity
+	}
+	byIdentity[membership.IdentityId] = membership.Id
+}
+
+func (s *organizationFallbackStore) recordMemberships(memberships []*organizationsv1.Membership) {
+	for _, membership := range memberships {
+		s.recordMembership(membership)
+	}
+}
+
+func (s *organizationFallbackStore) ensureMembership(
+	organizationID string,
+	identityID string,
+	role organizationsv1.MembershipRole,
+	status organizationsv1.MembershipStatus,
+) *organizationsv1.Membership {
+	if organizationID == "" || identityID == "" {
+		return nil
+	}
+
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	byIdentity, ok := s.membershipsByOrgIdentity[organizationID]
+	if ok {
+		if membershipID, exists := byIdentity[identityID]; exists {
+			return s.membershipsByID[membershipID]
+		}
+	} else {
+		byIdentity = make(map[string]string)
+		s.membershipsByOrgIdentity[organizationID] = byIdentity
+	}
+
+	membership := newFallbackMembership(organizationID, identityID, role, status)
+	s.membershipsByID[membership.Id] = membership
+	byIdentity[identityID] = membership.Id
+	return membership
+}
+
+func (s *organizationFallbackStore) updateMembershipRole(membershipID string, role organizationsv1.MembershipRole) (*organizationsv1.Membership, bool) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	membership, ok := s.membershipsByID[membershipID]
+	if !ok {
+		return nil, false
+	}
+	membership.Role = role
+	membership.UpdatedAt = timestamppb.Now()
+	return membership, true
+}
+
+func (s *organizationFallbackStore) updateMembershipStatus(membershipID string, status organizationsv1.MembershipStatus) (*organizationsv1.Membership, bool) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	membership, ok := s.membershipsByID[membershipID]
+	if !ok {
+		return nil, false
+	}
+	membership.Status = status
+	membership.UpdatedAt = timestamppb.Now()
+	return membership, true
+}
+
+func (s *organizationFallbackStore) removeMembership(membershipID string) bool {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	membership, ok := s.membershipsByID[membershipID]
+	if !ok {
+		return false
+	}
+	delete(s.membershipsByID, membershipID)
+	byIdentity, ok := s.membershipsByOrgIdentity[membership.OrganizationId]
+	if ok {
+		delete(byIdentity, membership.IdentityId)
+		if len(byIdentity) == 0 {
+			delete(s.membershipsByOrgIdentity, membership.OrganizationId)
+		}
+	}
+	return true
+}
+
+func (s *organizationFallbackStore) listMembers(organizationID string, status organizationsv1.MembershipStatus) []*organizationsv1.Membership {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	var memberships []*organizationsv1.Membership
+	for _, membership := range s.membershipsByID {
+		if membership.OrganizationId != organizationID {
+			continue
+		}
+		if status != organizationsv1.MembershipStatus_MEMBERSHIP_STATUS_UNSPECIFIED && membership.Status != status {
+			continue
+		}
+		memberships = append(memberships, membership)
+	}
+	return memberships
+}
+
+func (s *organizationFallbackStore) listByIdentity(identityID string, status organizationsv1.MembershipStatus) []*organizationsv1.Membership {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	var memberships []*organizationsv1.Membership
+	for _, membership := range s.membershipsByID {
+		if membership.IdentityId != identityID {
+			continue
+		}
+		if status != organizationsv1.MembershipStatus_MEMBERSHIP_STATUS_UNSPECIFIED && membership.Status != status {
+			continue
+		}
+		memberships = append(memberships, membership)
+	}
+	return memberships
+}
+
+func newFallbackMembership(
+	organizationID string,
+	identityID string,
+	role organizationsv1.MembershipRole,
+	status organizationsv1.MembershipStatus,
+) *organizationsv1.Membership {
+	now := timestamppb.Now()
+	return &organizationsv1.Membership{
+		Id:             uuid.NewString(),
+		OrganizationId: organizationID,
+		IdentityId:     identityID,
+		Role:           role,
+		Status:         status,
+		CreatedAt:      now,
+		UpdatedAt:      now,
+	}
+}
+
+func mergeOrganizations(primary []*organizationsv1.Organization, fallback []*organizationsv1.Organization) []*organizationsv1.Organization {
+	if len(fallback) == 0 {
+		return primary
+	}
+	merged := make([]*organizationsv1.Organization, 0, len(primary)+len(fallback))
+	seen := make(map[string]struct{}, len(primary))
+	for _, org := range primary {
+		if org == nil {
+			continue
+		}
+		if org.Id == "" {
+			merged = append(merged, org)
+			continue
+		}
+		if _, ok := seen[org.Id]; ok {
+			continue
+		}
+		seen[org.Id] = struct{}{}
+		merged = append(merged, org)
+	}
+	for _, org := range fallback {
+		if org == nil || org.Id == "" {
+			continue
+		}
+		if _, ok := seen[org.Id]; ok {
+			continue
+		}
+		seen[org.Id] = struct{}{}
+		merged = append(merged, org)
+	}
+	return merged
+}
+
+func mergeMemberships(primary []*organizationsv1.Membership, fallback []*organizationsv1.Membership) []*organizationsv1.Membership {
+	if len(fallback) == 0 {
+		return primary
+	}
+	merged := make([]*organizationsv1.Membership, 0, len(primary)+len(fallback))
+	seen := make(map[string]struct{}, len(primary))
+	for _, membership := range primary {
+		if membership == nil {
+			continue
+		}
+		if membership.Id == "" {
+			merged = append(merged, membership)
+			continue
+		}
+		if _, ok := seen[membership.Id]; ok {
+			continue
+		}
+		seen[membership.Id] = struct{}{}
+		merged = append(merged, membership)
+	}
+	for _, membership := range fallback {
+		if membership == nil || membership.Id == "" {
+			continue
+		}
+		if _, ok := seen[membership.Id]; ok {
+			continue
+		}
+		seen[membership.Id] = struct{}{}
+		merged = append(merged, membership)
+	}
+	return merged
+}
