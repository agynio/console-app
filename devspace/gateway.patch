+	}
+	merged := make([]*runnersv1.Runner, 0, len(primary)+len(fallback))
+	seen := make(map[string]struct{}, len(primary))
+	for _, runner := range primary {
+		if runner == nil {
+			continue
+		}
+		runnerID := runner.GetMeta().GetId()
+		if runnerID == "" {
+			merged = append(merged, runner)
+			continue
+		}
+		if _, ok := seen[runnerID]; ok {
+			continue
+		}
+		seen[runnerID] = struct{}{}
+		merged = append(merged, runner)
+	}
+	for _, runner := range fallback {
+		if runner == nil {
+			continue
+		}
+		runnerID := runner.GetMeta().GetId()
+		if runnerID == "" {
+			continue
+		}
+		if _, ok := seen[runnerID]; ok {
+			continue
+		}
+		seen[runnerID] = struct{}{}
+		merged = append(merged, runner)
+	}
+	return merged
+}
