+	"github.com/google/uuid"
+	"google.golang.org/protobuf/types/known/timestamppb"
+)
+
+type runnersFallbackStore struct {
+	mu          sync.RWMutex
+	runnersByID map[string]*runnersv1.Runner
+}
+
+func newRunnersFallbackStore() *runnersFallbackStore {
+	return &runnersFallbackStore{
+		runnersByID: make(map[string]*runnersv1.Runner),
+	}
+}
+
+func (s *runnersFallbackStore) recordRunner(runner *runnersv1.Runner) {
+	if runner == nil {
+		return
+	}
+	runnerID := runner.GetMeta().GetId()
+	if runnerID == "" {
+		return
+	}
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	s.runnersByID[runnerID] = runner
+}
+
+func (s *runnersFallbackStore) recordRunners(runners []*runnersv1.Runner) {
+	for _, runner := range runners {
+		s.recordRunner(runner)
+	}
+}
+
+func (s *runnersFallbackStore) getRunner(runnerID string) (*runnersv1.Runner, bool) {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	runner, ok := s.runnersByID[runnerID]
+	return runner, ok
+}
+
+func (s *runnersFallbackStore) listRunners(organizationID string) []*runnersv1.Runner {
+	if organizationID == "" {
+		s.ensureDefaultRunner()
+	}
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	runners := make([]*runnersv1.Runner, 0, len(s.runnersByID))
+	for _, runner := range s.runnersByID {
+		if organizationID != "" {
+			if runner.GetOrganizationId() != organizationID {
+				continue
+			}
+		} else if runner.GetOrganizationId() != "" {
+			continue
+		}
+		runners = append(runners, runner)
+	}
+	return runners
+}
+
+func (s *runnersFallbackStore) ensureDefaultRunner() *runnersv1.Runner {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	for _, runner := range s.runnersByID {
+		if runner.GetOrganizationId() == "" {
+			return runner
+		}
+	}
+	runner := newFallbackRunner()
+	s.runnersByID[runner.GetMeta().GetId()] = runner
+	return runner
+}
+
+func mergeRunners(primary []*runnersv1.Runner, fallback []*runnersv1.Runner) []*runnersv1.Runner {
